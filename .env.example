# =============================================================================
# FLOW Agent OS Environment Variables
# Copy this to .env and fill in your actual secrets
# =============================================================================

# ---------------------------------------------------------------------------
# AGENTS — Mercury 2, AgentZero, Hermes
# ---------------------------------------------------------------------------

# Mercury 2 Gateway Token (generate with: openssl rand -base64 32)
MERCURY2_GATEWAY_TOKEN=your_mercury2_gateway_token_here
MERCURY2_IMAGE=ghcr.io/erikhinla/mercury-2:latest

# AgentZero Web UI Auth
A0_AUTH_LOGIN=admin
A0_AUTH_PASSWORD=your_secure_password_here

# FLOW control plane auth
BIZBRAIN_ENV=prod
BIZBRAIN_API_TOKEN=your_bizbrain_api_token_here

# FLOW durable state database
FLOW_DB_PASSWORD=your_flow_db_password_here

# Hermes Configuration
# Use qwen2.5:3b (Ollama) or gpt-4.1-mini (OpenAI). Ollama is the default.
HERMES_DEFAULT_MODEL=qwen2.5:3b

# Ollama backend (used by Hermes when running locally or with Docker Compose)
# For local Docker Compose: http://ollama:11434/v1 (uses the ollama service name)
# For external VPS Ollama:  http://<VPS_IP>:11434/v1
OPENAI_BASE_URL=http://ollama:11434/v1

# ---------------------------------------------------------------------------
# LLM API KEYS (used by all agents)
# ---------------------------------------------------------------------------

OPENAI_API_KEY=sk-your_openai_key_here
GOOGLE_API_KEY=your_google_key_here
GROQ_API_KEY=your_groq_key_here

# OpenRouter — used by Hermes for model routing (required for Hermes to work)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ---------------------------------------------------------------------------
# INTEGRATIONS (optional)
# ---------------------------------------------------------------------------

GITHUB_TOKEN=ghp_your_github_token_here
DISCORD_TOKEN=your_discord_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

SOCIAL_HUB_API_ORIGIN=http://localhost:18000

# ---------------------------------------------------------------------------
# POSTIZ — Social Media Management
# ---------------------------------------------------------------------------

# Domain for Postiz access (set to your VPS IP or domain)
POSTIZ_DOMAIN=localhost:5000

# JWT Secret for Postiz (generate with: openssl rand -base64 32)
POSTIZ_JWT_SECRET=your_postiz_jwt_secret_here

# Postiz DB password
POSTIZ_DB_PASSWORD=your_postiz_db_password_here
