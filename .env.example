# =============================================================================
# FLOW Agent OS Environment Variables
# Copy this to .env and fill in your actual secrets
# =============================================================================

# ---------------------------------------------------------------------------
# AGENTS — OpenClaw, AgentZero, Hermes
# ---------------------------------------------------------------------------

# OpenClaw Gateway Token (generate with: openssl rand -base64 32)
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here

# Claude Web Integration (optional)
CLAUDE_AI_SESSION_KEY=your_claude_session_key_here
CLAUDE_WEB_SESSION_KEY=your_claude_web_session_here
CLAUDE_WEB_COOKIE=your_claude_web_cookie_here

# AgentZero Web UI Auth
A0_AUTH_LOGIN=admin
A0_AUTH_PASSWORD=your_secure_password_here

# Hermes Configuration
HERMES_DEFAULT_MODEL=claude-sonnet-4-5

# ---------------------------------------------------------------------------
# LLM API KEYS (used by all agents)
# ---------------------------------------------------------------------------

OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here
GROQ_API_KEY=your_groq_key_here

# ---------------------------------------------------------------------------
# INTEGRATIONS (optional)
# ---------------------------------------------------------------------------

GITHUB_TOKEN=ghp_your_github_token_here
DISCORD_TOKEN=your_discord_bot_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

# ---------------------------------------------------------------------------
# POSTIZ — Social Media Management
# ---------------------------------------------------------------------------

# Domain for Postiz access (set to your VPS IP or domain)
POSTIZ_DOMAIN=localhost:5000

# JWT Secret for Postiz (generate with: openssl rand -base64 32)
POSTIZ_JWT_SECRET=your_postiz_jwt_secret_here

# PostgreSQL Database Password
POSTIZ_DB_PASSWORD=your_secure_db_password_here

# Disable registration after first user (false = allow registration)
POSTIZ_DISABLE_REGISTRATION=false
