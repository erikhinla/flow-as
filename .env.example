# FLOW Agent AS environment template
# Copy this to .env and replace placeholders with real secrets.

# Core runtime
BIZBRAIN_ENV=prod
BIZBRAIN_API_TOKEN=replace_with_long_random_token
FLOW_DB_PASSWORD=replace_with_strong_password
WEBHOOK_API_KEY=replace_with_webhook_secret

# Dashboard
DASHBOARD_BASIC_AUTH_USER=admin
DASHBOARD_BASIC_AUTH_PASSWORD=replace_with_dashboard_password
SOCIAL_HUB_API_ORIGIN=http://localhost:5173

# Optional model/provider integrations
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
HERMES_DEFAULT_MODEL=

# Optional notifications/control surfaces
DISCORD_TOKEN=
DISCORD_WEBHOOK_URL=

# Optional legacy/operator values
MERCURY2_GATEWAY_TOKEN=

# AgentZero Web UI auth
A0_AUTH_LOGIN=admin
A0_AUTH_PASSWORD=

# Optional integration API keys
GOOGLE_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=
TELEGRAM_BOT_TOKEN=
FIRECRAWL_API_KEY=

# Optional Postiz/social stack values
POSTIZ_DOMAIN=localhost:5000
POSTIZ_JWT_SECRET=
POSTIZ_DB_PASSWORD=
