{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FAAS Task Envelope",
  "description": "Governed task envelope for FLOW Agent Architected Schemas.",
  "type": "object",
  "required": ["task_id", "created_at", "source", "title", "goal", "task_type", "risk_tier", "output_required", "review_required", "status"],
  "properties": {
    "task_id": {"type": "string", "description": "Idempotency key for the task"},
    "created_at": {"type": "string", "format": "date-time"},
    "source": {"type": "string", "enum": ["manual", "webhook", "github_action", "scheduled", "discord", "landing_page", "proof"]},
    "title": {"type": "string", "minLength": 5, "maxLength": 200},
    "goal": {"type": "string", "minLength": 10, "maxLength": 4000},
    "task_type": {
      "type": "string",
      "enum": ["classification", "rewrite", "content_prep", "artifact_production", "implementation", "skill_extraction", "healthcheck"]
    },
    "risk_tier": {"type": "string", "enum": ["low", "medium", "high"]},
    "priority": {"type": "string", "enum": ["low", "normal", "high", "urgent"], "default": "normal"},
    "preferred_owner": {"type": ["string", "null"], "enum": ["openclaw", "hermes", "agent_zero", null]},
    "owner_role": {"type": ["string", "null"], "enum": ["openclaw", "hermes", "agent_zero", null]},
    "inputs": {"type": "object"},
    "output_required": {"type": "string"},
    "review_required": {"type": "boolean"},
    "execution_approval_required": {"type": "boolean", "default": false},
    "rollback_required": {"type": "boolean", "default": false},
    "status": {
      "type": "string",
      "enum": ["pending", "validated", "queued", "active", "review_required", "completed", "failed", "dead_letter", "blocked", "escalated", "archived"],
      "default": "pending"
    }
  },
  "additionalProperties": false
}
