{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FAAS Reflection Record",
  "description": "Append-only post-execution reflection used for governed learning.",
  "type": "object",
  "required": ["reflection_id", "task_id", "job_id", "sequence_number", "owner", "what_worked", "what_failed", "created_at"],
  "properties": {
    "reflection_id": {"type": "string"},
    "task_id": {"type": "string"},
    "job_id": {"type": "string"},
    "sequence_number": {"type": "integer", "minimum": 1, "description": "Replay-safe sequence unique within task_id"},
    "owner": {"type": "string", "enum": ["openclaw", "hermes", "agent_zero"]},
    "what_worked": {"type": "string"},
    "what_failed": {"type": "string"},
    "pattern_observed": {"type": ["string", "null"]},
    "context_type": {"type": ["string", "null"]},
    "tool_sequence": {"type": ["array", "null"], "items": {"type": "string"}},
    "success_signal": {"type": ["string", "null"]},
    "failure_signal": {"type": ["string", "null"]},
    "sensitivity_level": {"type": "string", "enum": ["public", "internal", "redacted"], "default": "internal"},
    "created_at": {"type": "string", "format": "date-time"},
    "skill_extraction_attempted": {"type": "boolean", "default": false},
    "skills_extracted": {"type": ["array", "null"], "items": {"type": "string"}}
  },
  "additionalProperties": false
}
