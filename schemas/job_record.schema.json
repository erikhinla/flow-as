{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FAAS Job Record",
  "description": "Durable governed worker execution state stored in Postgres.",
  "type": "object",
  "required": ["job_id", "task_id", "owner", "status", "task_type", "risk_tier", "created_at"],
  "properties": {
    "job_id": {"type": "string"},
    "task_id": {"type": "string", "description": "Unique idempotency key"},
    "owner": {"type": "string", "enum": ["openclaw", "hermes", "agent_zero"]},
    "status": {"type": "string", "enum": ["pending", "validated", "queued", "active", "review_required", "completed", "failed", "dead_letter", "blocked", "escalated", "archived"]},
    "task_type": {"type": "string", "enum": ["classification", "rewrite", "content_prep", "artifact_production", "implementation", "skill_extraction", "healthcheck"]},
    "risk_tier": {"type": "string", "enum": ["low", "medium", "high"]},
    "priority": {"type": "string", "enum": ["low", "normal", "high", "urgent"]},
    "review_required": {"type": "boolean"},
    "execution_approval_required": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": ["string", "null"], "format": "date-time"},
    "started_at": {"type": ["string", "null"], "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "result_pointer": {"type": ["string", "null"]},
    "review_pointer": {"type": ["string", "null"]},
    "rollback_pointer": {"type": ["string", "null"]},
    "attempt_number": {"type": "integer", "minimum": 0},
    "claimed_by": {"type": ["string", "null"]},
    "lease_expires_at": {"type": ["string", "null"], "format": "date-time"},
    "retry_count": {"type": "integer", "minimum": 0},
    "max_retries": {"type": "integer", "minimum": 0},
    "error_message": {"type": ["string", "null"]},
    "escalation_triggered_at": {"type": ["string", "null"], "format": "date-time"},
    "escalation_notified_to": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
